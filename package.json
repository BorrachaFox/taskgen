{
  "name": "taskgen",
  "version": "1.0.0",
  "description": "AI-powered task creator for Linear via CLI",
  "type": "module",
  "bin": {
    "taskgen": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/cli.ts",
    "setup": "tsx src/cli.ts setup",
    "create": "tsx src/cli.ts create-task"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}